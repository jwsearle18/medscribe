# Backend environment variables — copy to `.env` and fill in.
# `.env` is gitignored; never commit real keys.

# Deepgram (speech-to-text). Free tier includes $200 credit.
# https://console.deepgram.com/
DEEPGRAM_API_KEY=

# Anthropic (note extraction via Claude tool-use).
# https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Supabase — from Project Settings → API.
# Use the SERVICE ROLE key (secret), not the anon key: the backend bypasses RLS.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
